schema doc {

    document doc {

        field name type string {
            indexing: index | summary
            index: enable-bm25
        }

        field display_name type string {
            indexing: index | summary
            index: enable-bm25
        }

        field about type string {
            indexing: index | summary
            index: enable-bm25
        }

        field pubkey type string {
            indexing: attribute | summary | index
            attribute: fast-search
        }

        field picture type string {
            indexing: summary
        }

        field banner type string {
            indexing: summary
        }

        field nip05 type string {
            indexing: summary
        }

        field lud06 type string {
            indexing: summary
        }

        field lud16 type string {
            indexing: summary
        }

        field website type string {
            indexing: summary
        }

        field quality_scores type tensor<int8>(user{}) {
            indexing: attribute
        }

        # Provenance: the id of the source event behind each piece of data, so a
        # NIP-09/NIP-62 deletion that references only an event id can be mirrored.
        # event_id is the kind:0 behind the profile fields; score_event_ids maps
        # observer pubkey -> the kind:30382 behind that observer's score cell.
        field event_id type string {
            indexing: attribute | summary
            attribute: fast-search
        }

        field score_event_ids type map<string, string> {
            indexing: summary
            struct-field key {
                indexing: attribute
                attribute: fast-search
            }
            struct-field value {
                indexing: attribute
                attribute: fast-search
            }
        }
    }

    field name_gram type string {
        indexing: input name | index
        index: enable-bm25
        match {
            gram
            gram-size: 3
        }
    }

    field display_name_gram type string {
        indexing: input display_name | index
        index: enable-bm25
        match {
            gram
            gram-size: 3
        }
    }

    field pubkey_gram type string {
        indexing: input pubkey | index
        index: enable-bm25
        match {
            gram
            gram-size: 3
        }
    }

    field about_gram type string {
        indexing: input about | index
        index: enable-bm25
        match {
            gram
            gram-size: 3
        }
    }

    fieldset default {
        fields: name, display_name, about
    }

    fieldset grams {
        fields: name_gram, display_name_gram, pubkey_gram
    }

    rank-profile name_only {
        first-phase {
            expression {
                matchCount(name) * 1000
                + bm25(name) / pow(fieldLength(name), 1.5)
            }
        }
    }

    rank-profile name_and_quality_score_only {

        inputs {
            query(user_q) tensor<float>(user{})
            query(w_gram) double: 1.0
            query(w_display_name) double: 0.2
            query(w_about) double: 0.5
            query(w_about_bonus) double: 0.0
            query(text_floor) double: 60.0
        }

        function user_score() {
            expression: sum(query(user_q) * attribute(quality_scores))
        }

        function quality_boost() {
            expression: 1000 / (1 + exp(-0.073 * (user_score() - 50)))
        }

        function gram_scale() {
            expression: min(query(w_gram), 1.0)
        }

        function name_exact() {
            expression {
                if(matchCount(name) > 0,
                    2000 + 200 * fieldMatch(name)
                         + if(fieldLength(name) > 0, bm25(name) / pow(fieldLength(name), 1.5), 0),
                    0)
            }
        }
        function display_name_exact() {
            expression {
                if(matchCount(display_name) > 0,
                    2000 + 200 * fieldMatch(display_name)
                         + if(fieldLength(display_name) > 0, bm25(display_name) / pow(fieldLength(display_name), 1.5), 0),
                    0)
            }
        }

        function name_gram_score() {
            expression {
                if(matchCount(name) == 0 && matchCount(name_gram) > 0,
                    gram_scale() * 300 * pow(fieldMatch(name_gram).queryCompleteness, 2),
                    0)
            }
        }
        function display_name_gram_score() {
            expression {
                if(matchCount(display_name) == 0 && matchCount(display_name_gram) > 0,
                    gram_scale() * 300 * pow(fieldMatch(display_name_gram).queryCompleteness, 2),
                    0)
            }
        }

        function name_text() {
            expression: name_exact() + name_gram_score()
        }
        function display_name_text() {
            expression: display_name_exact() + display_name_gram_score()
        }

        function primary_text() {
            expression: max(name_text(), display_name_text())
        }

        function secondary_active() {
            expression: if(matchCount(name) > 0 || matchCount(display_name) > 0, 0, 1)
        }

        function has_exact_match() {
            expression: if(matchCount(name) > 0 || matchCount(display_name) > 0 || matchCount(about) > 0, 1, 0)
        }

        function about_text() {
            expression {
                bm25(about)
                + if(matchCount(about) == 0 && matchCount(about_gram) > 0,
                     gram_scale() * 100 * pow(fieldMatch(about_gram).queryCompleteness, 2),
                     0)
            }
        }

        function text_score() {
            expression: primary_text() + secondary_active() * query(w_about) * about_text()
        }

        function quality_gate() {
            expression: min(text_score() / 2000.0, 1.0)
        }

        first-phase {
            expression: text_score()
        }

        second-phase {
            expression {
                if(has_exact_match() == 0 && text_score() < query(text_floor), -1, text_score() + quality_gate() * quality_boost())
            }
            rank-score-drop-limit: 0.0
        }

        match-features {
            user_score
            quality_boost
            text_score
            name_text
            display_name_text
            about_text
        }
    }

    rank-profile search_rank {

        inputs {
            query(qlen) double: 5.0
            query(w_name) double: 3.0
            query(w_display_name) double: 3.0
            query(w_about) double: 1.0
            query(w_name_gram) double: 0.5
            query(w_display_name_gram) double: 0.5
            query(w_pubkey_gram) double: 0.1
            query(w_quality) double: 1.0
            query(user_q) tensor<float>(user{})
        }

        function user_score() {
            expression: sum(query(user_q) * attribute(quality_scores))
        }

        match-features {
            user_score
        }

        first-phase {
            expression {
                (
                    min(query(qlen) / 5.0, 1.0) *
                        (
                            query(w_name) * bm25(name)
                            + query(w_display_name) * bm25(display_name)
                            + query(w_about) * bm25(about)
                        )
                    + max(1.5 - query(qlen) / 8.0, 0.3) *
                        (
                            query(w_name_gram) * bm25(name_gram)
                            + query(w_display_name_gram) * bm25(display_name_gram)
                        )
                    + query(w_pubkey_gram) * bm25(pubkey_gram)
                )
                * if(user_score() > 0, pow(1 + user_score(), query(w_quality)), 1)
            }
        }
    }
}
